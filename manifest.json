{
  "name": "Vimput",
  "description": "Bind vim motions to every input",
  "version": "0.1.0",
  "manifest_version": 3,
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["target.js", "content.js"],
      "css": ["index.css"],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_icon": "assets/vim.png"
  },
  "icons": {
    "128": "assets/vim.png"
  }
}
